  "compilerOptions": {
    "module" :"commonjs", //모듈 시스템 설정 (Node.js용)
    "target" :"es6", // 트랜스파일 결과의 자바스크립트 버전.
    "strictNullChecks": true // null과 undefined를 모든 타입에 할당할 수 없도록 설정
  }
}